generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model users {
  id_user    String   @id @default(dbgenerated("auth.uid()")) @db.Uuid
  username   String   @unique @default("255") @db.VarChar(255)
  email      String   @unique @default("255") @db.VarChar(255)
  password   String   @default("255") @db.VarChar(255)
  created_at DateTime @default(dbgenerated("(now() AT TIME ZONE 'utc'::text)")) @db.Timestamptz(6)
  updated_at DateTime @default(dbgenerated("(now() AT TIME ZONE 'utc'::text)")) @db.Timestamptz(6)
}

model blogs {
  id_blog     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  image       String?
  title       String   @unique @default("255") @db.VarChar(255)
  description String   @default("255") @db.VarChar(255)
  content     String
  created_at  DateTime @db.Timestamptz(6)
}